# !/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"

##### Constants #####
BAR_COLOR=0x00000000
ITEM_BG_COLOR=0x7a121212
ITEM_LABEL_COLOR=0xffffffff
ITEM_ICON_COLOR=0xffffffff
BORDER_COLOR=0x36ffffff
BORDER_WIDTH=1
HEIGHT=30
RADIUS=15

##### Bar Appearance #####
bar=(
  position=top
  height=30
  margin=8
  color=$BAR_COLOR
  blur_radius=20
  padding_left=0
  padding_right=0
)

sketchybar --bar "${bar[@]}"

##### Adding Events #####
BLUETOOTH_EVENT="com.apple.bluetooth.status"
sketchybar --add event bluetooth_update $BLUETOOTH_EVENT

#### Defaults #####
default=(
  drawing=on
  updates=on
  icon.color=$ITEM_ICON_COLOR
  label.color=$ITEM_LABEL_COLOR
  padding_left=2
  padding_right=2
  icon.font="SF Pro:Bold:16"
  label.font="SF Pro:Semibold:14"
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)

sketchybar --default "${default[@]}"

##### Adding Left Items #####
source $ITEM_DIR/apple.sh
source $ITEM_DIR/front_app.sh

##### Adding Center Items #####
source $ITEM_DIR/apple_music.sh

##### Adding Right Items #####
source $ITEM_DIR/calendar.sh
source $ITEM_DIR/wifi.sh
source $ITEM_DIR/battery.sh
source $ITEM_DIR/memory.sh
source $ITEM_DIR/cpu.sh
source $ITEM_DIR/pomodoro.sh
source $ITEM_DIR/kanata.sh

##### Grouping Items into Brackets #####
# Left side - Apple pill
sketchybar --add bracket apple_pill \
            apple \
           --set apple_pill background.color=$ITEM_BG_COLOR \
                            background.height=$HEIGHT \
                            background.corner_radius=$RADIUS \
                            background.border_width=$BORDER_WIDTH \
                            background.border_color=$BORDER_COLOR \
                            blur_radius=4 \

# Left side - Front App pill
sketchybar --add bracket front_app_pill \
            front_app \
           --set front_app_pill background.color=$ITEM_BG_COLOR \
                    background.height=$HEIGHT \
                    background.corner_radius=$RADIUS \
                    background.border_width=$BORDER_WIDTH \
                    background.border_color=$BORDER_COLOR \
                    blur_radius=4 \

# Right side pill
sketchybar --add bracket right_pill \
            calendar \
            wifi \
            battery \
            cpu \
            memory \
            pomodoro \
            kanata \
           --set right_pill background.color=$ITEM_BG_COLOR \
                            background.height=$HEIGHT \
                            background.corner_radius=$RADIUS \
                            background.border_width=$BORDER_WIDTH \
                            background.border_color=$BORDER_COLOR \
                            blur_radius=4 \

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update

